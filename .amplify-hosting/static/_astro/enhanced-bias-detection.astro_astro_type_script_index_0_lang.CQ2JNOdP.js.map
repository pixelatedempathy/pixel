  // Analytics tracking for demo interactions
  document.addEventListener('DOMContentLoaded', () => {
    // Track demo page view
    if (typeof gtag !== 'undefined') {
      gtag('event', 'page_view', {
        page_title: 'Enhanced Bias Detection Demo',
        page_location: window.location.href,
        content_group1: 'Demo Pages',
      })
    }

    // Track demo interactions
    const demoContainer = document.querySelector('.bias-detection-demo')
    if (demoContainer) {
      // Track analysis starts
      demoContainer.addEventListener('click', (e) => {
        if (e.target?.textContent?.includes('Analyze for Bias')) {
          if (typeof gtag !== 'undefined') {
            gtag('event', 'demo_interaction', {
              event_category: 'Bias Detection Demo',
              event_label: 'Analysis Started',
              value: 1,
            })
          }
        }
      })

      // Track preset selections
      demoContainer.addEventListener('click', (e) => {
        if (e.target?.closest('.preset-scenario-selector')) {
          if (typeof gtag !== 'undefined') {
            gtag('event', 'demo_interaction', {
              event_category: 'Bias Detection Demo',
              event_label: 'Preset Selected',
              value: 1,
            })
          }
        }
      })

      // Track exports
      demoContainer.addEventListener('click', (e) => {
        if (e.target?.textContent?.includes('Export Data')) {
          if (typeof gtag !== 'undefined') {
            gtag('event', 'demo_interaction', {
              event_category: 'Bias Detection Demo',
              event_label: 'Data Exported',
              value: 1,
            })
          }
        }
      })
    }
  })


