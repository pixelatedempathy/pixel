          // Show notification for new issues
          toast.error(
            `${newIssues.length} New Compatibility ${newIssues.length === 1 ? 'Issue' : 'Issues'}! New compatibility issues have been detected. Refresh to view details.`,
            {
              duration: 10000,
            },
          )

