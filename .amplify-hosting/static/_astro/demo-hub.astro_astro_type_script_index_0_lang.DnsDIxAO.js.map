  declare const gtag: Function;
  // Add demo grid class for smooth scrolling reference
  document.addEventListener('DOMContentLoaded', () => {
    const demoGrid = document.querySelector(
      '.grid.grid-cols-1.lg\\:grid-cols-2',
    )
    if (demoGrid) {
      demoGrid.classList.add('demo-grid')
    }

    // Handle demo navigation
    document.querySelectorAll('[data-demo-link]').forEach((button) => {
      button.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        const link = target.dataset['demoLink'];
        if (link) {
          window.location.href = link
        }
      })
    })

    // Handle scroll to demo grid
    document.querySelectorAll('[data-scroll-to]').forEach((button) => {
      button.addEventListener('click', (e) => {
        const eventTarget = e.target as HTMLElement;
        const target = eventTarget.dataset['scrollTo'];
        if (target === 'demo-grid') {
          const element = document.querySelector('.demo-grid')
          if (element) {
            element.scrollIntoView({ behavior: 'smooth' })
          }
        }
      })
    })

    // Handle contact navigation
    document.querySelectorAll('[data-contact-link]').forEach((button) => {
      button.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        const link = target.dataset['contactLink'];
        if (link) {
          window.location.href = link
        }
      })
    })

    // Track demo hub interactions
    document.querySelectorAll('button[data-demo-link]').forEach((button) => {
      button.addEventListener('click', (e) => {
        if (typeof gtag !== 'undefined') {
          const target = e.target as HTMLElement;
          gtag('event', 'demo_hub_interaction', {
            demo_selected: target.textContent,
            page_location: window.location.href,
          })
        }
      })
    })
  })


