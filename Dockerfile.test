# syntax = docker/dockerfile:1

# Minimal test Dockerfile to verify Docker build works
ARG NODE_VERSION=22
FROM public.ecr.aws/bitnami/node:${NODE_VERSION}-debian-12 AS base

LABEL org.opencontainers.image.description="Pixelated Astro App Test"

# Install system dependencies
RUN DEBIAN_FRONTEND=noninteractive apt-get update && apt-get install -y \
    curl \
    ca-certificates \
    build-essential \
    python3 \
    make \
    g++ \
    && rm -rf /var/lib/apt/lists/*

# Set working directory
WORKDIR /app

# Copy package files
COPY package.json pnpm-lock.yaml ./

# Install dependencies
RUN npm install -g pnpm@10.13.1 && \
    pnpm install --frozen-lockfile

# Copy source code
COPY . .

# Create minimal environment file
RUN echo "NODE_ENV=production" > .env.prod && \
    echo "PORT=3000" >> .env.prod && \
    echo "HOST=0.0.0.0" >> .env.prod

# Build the application
RUN pnpm run build

# Copy startup script and make executable
COPY scripts/docker-startup.sh /app/startup.sh
RUN chmod +x /app/startup.sh

# Create astro user
RUN groupadd -r astro && useradd -r -g astro astro && \
    chown -R astro:astro /app

USER astro

# Expose port
EXPOSE 3000

# Start the application
CMD ["/app/startup.sh"]
